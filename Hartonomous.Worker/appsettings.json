{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=hartonomous_dev;Username=postgres;Password=PLACEHOLDER",
    "Redis": "",
    "BlobStorage": "file://local_storage",
    "MessageQueue": "InMemory"
  },
  "Redis": {
    "InstanceName": "Hartonomous_"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Hartonomous.Worker": "Information"
    }
  },
  "Workers": {
    "ContentProcessing": {
      "MaxParallelism": 3,
      "PollingIntervalSeconds": 10,
      "ConstantBatchSize": 1000
    },
    "BPELearning": {
      "Schedule": "0 2 * * *",
      "MinConstantsThreshold": 10000,
      "MaxVocabularySize": 50000,
      "MergeIterations": 1000
    },
    "ConstantIndexing": {
      "PollingIntervalSeconds": 30,
      "BatchSize": 5000,
      "EnableOptimization": true,
      "OptimizationSchedule": "0 3 * * 0"
    },
    "LandmarkDetection": {
      "Schedule": "0 */6 * * *",
      "MinClusterSize": 100,
      "EpsilonDistance": 0.1,
      "UpdateExistingLandmarks": true,
      "MaxLandmarkRadius": 1.0
    }
  }
}

