{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=hartonomous;Username=hartonomous_user",
    "RedisConnection": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000"
  },

  "Azure": {
    "KeyVault": {
      "VaultUri": "https://hartonomous-kv.vault.azure.net/"
    },
    "ManagedIdentity": {
      "ClientId": null
    },
    "AppConfiguration": {
      "Endpoint": "https://appconfig-hartonomous.azconfig.io"
    }
  },

  "Redis": {
    "Configuration": "localhost:6379",
    "InstanceName": "Hartonomous:"
  },

  "Database": {
    "Provider": "PostgreSQL",
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": true,
    "CommandTimeout": 30,
    "MaxRetryCount": 3,
    "MaxRetryDelay": 30
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    },
    "Limits": {
      "MaxRequestBodySize": 104857600,
      "RequestHeadersTimeout": "00:00:30"
    }
  },

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "Audience": "api://hartonomous-api",
    "Scopes": "access_as_user"
  },

  "ExternalId": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "Authority": "https://your-b2c-tenant.b2clogin.com/your-b2c-tenant.onmicrosoft.com/B2C_1_signupsignin"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://hartonomous.local",
      "https://web.hartonomous.local"
    ],
    "AllowCredentials": true
  },

  "Hartonomous": {
    "ContentAddressableStorage": {
      "Provider": "PostgreSQL",
      "ChunkSize": 4096,
      "EnableDeduplication": true,
      "HilbertCurveOrder": 16
    },
    "BPE": {
      "VocabularySize": 50000,
      "MinFrequency": 2
    }
  }
}
