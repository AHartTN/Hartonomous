{
  "environment": "staging",
  "target": {
    "machine": "hart-server",
    "os": "linux",
    "runner_labels": ["self-hosted", "linux", "hart-server"]
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "hartonomous_staging",
    "user": "hartonomous",
    "ssl_mode": "require",
    "backup_enabled": true,
    "migration_timeout": 600
  },
  "neo4j": {
    "uri": "bolt://localhost:7687",
    "user": "neo4j",
    "database": "hartonomous_staging",
    "edition": "community"
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8001,
    "workers": 8,
    "reload": false,
    "log_level": "INFO"
  },
  "azure": {
    "resource_group": "rg-hartonomous",
    "key_vault_name": "kv-hartonomous",
    "key_vault_url": "https://kv-hartonomous.vault.azure.net",
    "app_config_endpoint": "https://appconfig-hartonomous.azconfig.io",
    "use_managed_identity": true
  },
  "deployment": {
    "install_path": "/srv/www/staging",
    "backup_path": "/var/backups/hartonomous/staging",
    "log_path": "/var/log/hartonomous/staging",
    "service_name": "hartonomous-api-staging",
    "auto_rollback": true,
    "skip_tests": false
  },
  "secrets": {
    "postgres_password": "PostgreSQL-Hartonomous-Staging-Password",
    "neo4j_password": "Neo4j-Staging-Password",
    "azure_client_secret": "AzureAd-ClientSecret-Staging"
  },
  "features": {
    "neo4j_enabled": true,
    "age_worker_enabled": false,
    "auth_enabled": true,
    "b2c_enabled": false
  }
}
