{
  "environment": "development",
  "target": {
    "machine": "HART-DESKTOP",
    "os": "windows",
    "runner_labels": ["self-hosted", "windows", "HART-DESKTOP"]
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "Hartonomous-DEV-development",
    "ssl_mode": "prefer",
    "backup_enabled": true,
    "migration_timeout": 300
  },
  "neo4j": {
    "uri": "bolt://localhost:7687",
    "database": "neo4j",
    "edition": "desktop"
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8000,
    "workers": 4,
    "reload": true,
    "log_level": "DEBUG"
  },
  "azure": {
    "resource_group": "rg-hartonomous",
    "key_vault_name": "kv-hartonomous",
    "app_config_endpoint": "https://appconfig-hartonomous.azconfig.io",
    "use_managed_identity": false
  },
  "deployment": {
    "install_path": "D:/Hartonomous/api",
    "backup_path": "D:/Hartonomous/backups",
    "log_path": "D:/Hartonomous/logs",
    "service_name": "Hartonomous-API-Dev",
    "auto_rollback": true,
    "skip_tests": false
  },
  "secrets": {
    "postgres_password": "PostgreSQL-Hartonomous-Password",
    "neo4j_password": null,
    "azure_client_secret": "AzureAd-ClientSecret"
  },
  "features": {
    "neo4j_enabled": true,
    "age_worker_enabled": false,
    "auth_enabled": false,
    "b2c_enabled": false
  }
}
