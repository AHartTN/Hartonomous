{
  "environment": "localhost",
  "target": {
    "machine": "localhost",
    "os": "any",
    "runner_labels": []
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "hartonomous_local",
    "user": "postgres",
    "ssl_mode": "disable",
    "backup_enabled": false,
    "migration_timeout": 300
  },
  "neo4j": {
    "uri": "bolt://localhost:7687",
    "user": "neo4j",
    "database": "neo4j",
    "edition": "desktop"
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8000,
    "workers": 1,
    "reload": true,
    "log_level": "DEBUG"
  },
  "azure": {
    "resource_group": null,
    "key_vault_name": null,
    "key_vault_url": null,
    "app_config_endpoint": null,
    "use_managed_identity": false
  },
  "deployment": {
    "install_path": "./api",
    "backup_path": "./backups",
    "log_path": "./logs",
    "service_name": null,
    "auto_rollback": false,
    "skip_tests": false
  },
  "secrets": {
    "postgres_password": null,
    "neo4j_password": null,
    "azure_client_secret": null
  },
  "features": {
    "neo4j_enabled": false,
    "age_worker_enabled": false,
    "auth_enabled": false,
    "b2c_enabled": false
  }
}
