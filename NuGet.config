<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Azure Artifacts Feed for Internal Packages -->
    <!-- URL automatically retrieved from Key Vault during pipeline execution -->
    <!-- For local development, run: az keyvault secret show --vault-name <kv-name> --name "NuGetFeedUrl" --query value -o tsv -->
    <add key="Hartonomous" value="https://pkgs.dev.azure.com/aharttn/Hartonomous/_packaging/Hartonomous/nuget/v3/index.json" />
    
    <!-- NuGet.org for Public Packages -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  
  <packageSourceMapping>
    <!-- Internal packages from Azure Artifacts -->
    <packageSource key="Hartonomous">
      <package pattern="Hartonomous.*" />
    </packageSource>
    
    <!-- All other packages from NuGet.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  
  <disabledPackageSources />
  
  <config>
    <add key="defaultPushSource" value="https://pkgs.dev.azure.com/aharttn/Hartonomous/_packaging/Hartonomous/nuget/v3/index.json" />
  </config>
</configuration>
