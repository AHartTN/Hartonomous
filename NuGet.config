<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="Hartonomous" value="https://pkgs.dev.azure.com/aharttn/Hartonomous/_packaging/Hartonomous/nuget/v3/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  
  <packageSourceMapping>
    <packageSource key="Hartonomous">
      <package pattern="Hartonomous.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  
  <disabledPackageSources />
  
  <config>
    <add key="defaultPushSource" value="https://pkgs.dev.azure.com/aharttn/Hartonomous/_packaging/Hartonomous/nuget/v3/index.json" />
  </config>
</configuration>
