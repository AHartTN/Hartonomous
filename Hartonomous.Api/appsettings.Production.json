{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=hartonomous_prod;Username=hartonomous;Password=${DB_PASSWORD}",
    "Redis": "localhost:6379,abortConnect=false,ssl=false"
  },
  "Authentication": {
    "Authority": "https://login.microsoftonline.com/${TENANT_ID}",
    "TenantId": "${TENANT_ID}",
    "ClientId": "${CLIENT_ID}",
    "Audience": "api://hartonomous-api",
    "Instance": "https://login.microsoftonline.com/"
  },
  "KeyVault": {
    "Uri": "https://hartonomous-kv.vault.azure.net/",
    "Name": "hartonomous-kv"
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 1000,
      "QueueLimit": 100
    },
    "Fixed": {
      "PermitLimit": 100,
      "QueueLimit": 10
    },
    "Sliding": {
      "PermitLimit": 100,
      "QueueLimit": 10
    },
    "Token": {
      "TokenLimit": 100,
      "TokensPerPeriod": 10,
      "QueueLimit": 10
    },
    "Concurrency": {
      "PermitLimit": 50,
      "QueueLimit": 20
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.hartonomous.com",
      "https://api.hartonomous.com"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "Hartonomous.API",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Kestrel": {
    "Limits": {
      "MaxConcurrentConnections": 1000,
      "MaxConcurrentUpgradedConnections": 1000,
      "MaxRequestBodySize": 10485760,
      "KeepAliveTimeout": "00:02:00",
      "RequestHeadersTimeout": "00:00:30"
    },
    "EndPoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  }
}
