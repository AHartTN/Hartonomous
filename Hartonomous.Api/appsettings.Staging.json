{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=hartonomous_staging;Username=hartonomous;Password=${DB_PASSWORD}",
    "Redis": "localhost:6379,abortConnect=false,ssl=false"
  },
  "Authentication": {
    "Authority": "https://login.microsoftonline.com/${TENANT_ID}",
    "TenantId": "${TENANT_ID}",
    "ClientId": "${CLIENT_ID}",
    "Audience": "api://hartonomous-api-staging",
    "Instance": "https://login.microsoftonline.com/"
  },
  "KeyVault": {
    "Uri": "https://hartonomous-staging-kv.vault.azure.net/",
    "Name": "hartonomous-staging-kv"
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 5000,
      "QueueLimit": 200
    },
    "Fixed": {
      "PermitLimit": 500,
      "QueueLimit": 50
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app-staging.hartonomous.com",
      "https://api-staging.hartonomous.com"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "Hartonomous.API.Staging",
    "ServiceVersion": "1.0.0-staging",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Kestrel": {
    "Limits": {
      "MaxConcurrentConnections": 500,
      "MaxConcurrentUpgradedConnections": 500,
      "MaxRequestBodySize": 10485760,
      "KeepAliveTimeout": "00:02:00"
    },
    "EndPoints": {
      "Http": {
        "Url": "http://localhost:5001"
      }
    }
  }
}
