@page "/atoms"
@inject IAtomService AtomService

<PageTitle>Atoms</PageTitle>

<h1>Atoms</h1>

<p>Manage atomic data components</p>

@if (atoms == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Type</th>
                <th>Hash</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var atom in atoms)
            {
                <tr>
                    <td>@atom.Id</td>
                    <td>@atom.AtomType</td>
                    <td><code>@atom.ContentHash.Substring(0, 16)...</code></td>
                    <td>@atom.CreatedAt.ToLocalTime()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Hartonomous.Shared.Models.AtomDto>? atoms;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            atoms = await AtomService.GetAtomsByTypeAsync("tensor", 0, 50);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading atoms: {ex.Message}");
            atoms = new List<Hartonomous.Shared.Models.AtomDto>();
        }
    }
}
