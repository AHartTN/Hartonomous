@page "/tensors"
@inject ITensorService TensorService

<PageTitle>Tensors</PageTitle>

<h1>Tensor Chunks</h1>

<p>View and search tensor data with spatial indexing</p>

@if (chunks == null)
{
    <p><em>Loading...</em></p>
}
else if (!chunks.Any())
{
    <div class="alert alert-warning">
        No tensor chunks found. Start by ingesting a model.
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tensor Name</th>
                <th>Shape</th>
                <th>Hash</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var chunk in chunks)
            {
                <tr>
                    <td>@chunk.Id</td>
                    <td>@chunk.TensorName</td>
                    <td>[@string.Join(", ", chunk.Shape)]</td>
                    <td><code>@chunk.ContentHash.Substring(0, 16)...</code></td>
                    <td>@chunk.CreatedAt.ToLocalTime()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Hartonomous.Shared.Models.TensorChunkDto>? chunks;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            chunks = new List<Hartonomous.Shared.Models.TensorChunkDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tensor chunks: {ex.Message}");
            chunks = new List<Hartonomous.Shared.Models.TensorChunkDto>();
        }
    }
}
