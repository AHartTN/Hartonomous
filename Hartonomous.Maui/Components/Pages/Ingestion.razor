@page "/ingestion"
@inject IIngestionService IngestionService

<PageTitle>Ingestion</PageTitle>

<h1>Ingestion Jobs</h1>

<p>Monitor and manage data ingestion processes</p>

@if (jobs == null)
{
    <p><em>Loading...</em></p>
}
else if (!jobs.Any())
{
    <div class="alert alert-info">
        No active ingestion jobs.
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Type</th>
                <th>Status</th>
                <th>Progress</th>
                <th>Started</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in jobs)
            {
                <tr>
                    <td>@job.Id</td>
                    <td>@job.JobType</td>
                    <td><span class="badge bg-@GetStatusColor(job.JobStatus)">@job.JobStatus</span></td>
                    <td>
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="width: @job.ProgressPercentage%" aria-valuenow="@job.ProgressPercentage" aria-valuemin="0" aria-valuemax="100">
                                @job.ProgressPercentage.ToString("F1")%
                            </div>
                        </div>
                    </td>
                    <td>@job.StartedAt.ToLocalTime()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Hartonomous.Shared.Models.IngestionJobDto>? jobs;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobsAsync();
    }

    private async Task LoadJobsAsync()
    {
        try
        {
            jobs = await IngestionService.GetActiveJobsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading jobs: {ex.Message}");
            jobs = new List<Hartonomous.Shared.Models.IngestionJobDto>();
        }
    }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Pending" => "secondary",
            "Running" => "primary",
            "Completed" => "success",
            "Failed" => "danger",
            "Cancelled" => "warning",
            _ => "secondary"
        };
    }
}
