<Project>

  <!-- ======================================
       Global Build Configuration
       ====================================== -->
  <PropertyGroup Label="Build">
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <AnalysisMode>Default</AnalysisMode>
    
    <!-- Ensure proper obj/bin folder isolation -->
    <BaseIntermediateOutputPath>obj\</BaseIntermediateOutputPath>
    <IntermediateOutputPath>$(BaseIntermediateOutputPath)$(Configuration)\</IntermediateOutputPath>
    
    <!-- Centralized artifacts output -->
    <ArtifactsPath Condition="'$(ArtifactsPath)' == ''">$(MSBuildThisFileDirectory)artifacts</ArtifactsPath>
    <BaseOutputPath>$(ArtifactsPath)\bin\$(MSBuildProjectName)\</BaseOutputPath>
    <OutputPath>$(BaseOutputPath)$(Configuration)\</OutputPath>
    <PackageOutputPath>$(ArtifactsPath)\packages\</PackageOutputPath>
  </PropertyGroup>

  <!-- ======================================
       Environment Configuration
       ====================================== -->
  <PropertyGroup Label="Environment">
    <EnvironmentName Condition="'$(Configuration)' == 'Debug'">Local</EnvironmentName>
    <EnvironmentName Condition="'$(Configuration)' == 'Dev'">Dev</EnvironmentName>
    <EnvironmentName Condition="'$(Configuration)' == 'Staging'">Staging</EnvironmentName>
    <EnvironmentName Condition="'$(Configuration)' == 'Release'">Production</EnvironmentName>
    <EnvironmentName Condition="'$(Configuration)' == 'Production'">Production</EnvironmentName>
    <EnvironmentName Condition="'$(EnvironmentName)' == ''">Local</EnvironmentName>
  </PropertyGroup>

  <!-- ======================================
       Debug/Local Configuration
       ====================================== -->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug' OR '$(Configuration)' == ''">
    <DefineConstants>$(DefineConstants);DEBUG;TRACE;LOCAL</DefineConstants>
    <Optimize>false</Optimize>
    <DebugType>embedded</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <!-- ======================================
       Development Configuration
       ====================================== -->
  <PropertyGroup Condition="'$(Configuration)' == 'Dev'">
    <DefineConstants>$(DefineConstants);TRACE;DEV</DefineConstants>
    <Optimize>false</Optimize>
    <DebugType>embedded</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <!-- ======================================
       Staging Configuration
       ====================================== -->
  <PropertyGroup Condition="'$(Configuration)' == 'Staging'">
    <DefineConstants>$(DefineConstants);TRACE;STAGING</DefineConstants>
    <Optimize>true</Optimize>
    <DebugType>embedded</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <!-- ======================================
       Production/Release Configuration
       ====================================== -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release' OR '$(Configuration)' == 'Production'">
    <DefineConstants>$(DefineConstants);TRACE;PRODUCTION</DefineConstants>
    <Optimize>true</Optimize>
    <DebugType>embedded</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <!-- ======================================
       Deterministic and CI Builds
       ====================================== -->
  <PropertyGroup Label="CI">
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true' or '$(TF_BUILD)' == 'True'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <!-- ======================================
       Source Control and SourceLink
       ====================================== -->
  <PropertyGroup Label="SourceControl">
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <RepositoryUrl>https://dev.azure.com/aharttn/Hartonomous/_git/Hartonomous</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <!-- ======================================
       NuGet Package Configuration
       ====================================== -->
  <PropertyGroup Label="NuGet" Condition="'$(IsPackable)' == 'true'">
    <PackageProjectUrl>https://dev.azure.com/aharttn/Hartonomous</PackageProjectUrl>
    <PackageLicenseExpression>Proprietary</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <!-- ======================================
       Common Package References
       ====================================== -->
  <ItemGroup Label="Code Analysis">
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" Version="9.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Label="Source Link">
    <PackageReference Include="Microsoft.SourceLink.AzureRepos.Git" Version="8.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
