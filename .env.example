# Example Environment Variables
# Copy this file to .env.localhost, .env.dev, .env.staging, or .env.production
# and update the values accordingly

ASPNETCORE_ENVIRONMENT=localhost
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=hartonomous_localhost;Username=postgres;Password=YOUR_PASSWORD;Include Error Detail=true

# Database Configuration
DB_MAX_RETRY_COUNT=3
DB_COMMAND_TIMEOUT=30
DB_ENABLE_SENSITIVE_LOGGING=true
DB_ENABLE_DETAILED_ERRORS=true

# Docker Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=hartonomous_localhost
POSTGRES_PORT=5432
