# Staging Environment Variables
ASPNETCORE_ENVIRONMENT=staging
DB_CONNECTION_STRING=Host=localhost;Port=5434;Database=hartonomous_staging;Username=postgres;Password=postgres_staging;Include Error Detail=true

# Database Configuration
DB_MAX_RETRY_COUNT=3
DB_COMMAND_TIMEOUT=30
DB_ENABLE_SENSITIVE_LOGGING=false
DB_ENABLE_DETAILED_ERRORS=true

# Docker Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_staging
POSTGRES_DB=hartonomous_staging
POSTGRES_PORT=5434
