# Development Environment Variables
ASPNETCORE_ENVIRONMENT=dev
DB_CONNECTION_STRING=Host=localhost;Port=5433;Database=hartonomous_dev;Username=postgres;Password=postgres_dev;Include Error Detail=true

# Database Configuration
DB_MAX_RETRY_COUNT=3
DB_COMMAND_TIMEOUT=30
DB_ENABLE_SENSITIVE_LOGGING=true
DB_ENABLE_DETAILED_ERRORS=true

# Docker Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev
POSTGRES_DB=hartonomous_dev
POSTGRES_PORT=5433
