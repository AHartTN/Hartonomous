# Production Environment Variables
ASPNETCORE_ENVIRONMENT=production
DB_CONNECTION_STRING=Host=localhost;Port=5435;Database=hartonomous_production;Username=postgres;Password=postgres_prod;Include Error Detail=false

# Database Configuration
DB_MAX_RETRY_COUNT=3
DB_COMMAND_TIMEOUT=30
DB_ENABLE_SENSITIVE_LOGGING=false
DB_ENABLE_DETAILED_ERRORS=false

# Docker Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_prod
POSTGRES_DB=hartonomous_production
POSTGRES_PORT=5435
