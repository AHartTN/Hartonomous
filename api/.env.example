# Hartonomous API - Local Development Configuration
# ⚠️  SECURITY WARNING: This file contains DEFAULT/EXAMPLE values only!
# ⚠️  DO NOT commit real credentials to git!
# ⚠️  Copy to .env and change ALL passwords before use!
#
# For Azure deployment, set USE_AZURE_CONFIG=true

# ====================================
# DEVELOPMENT MODE (Local)
# ====================================
USE_AZURE_CONFIG=false

# Database (Local PostgreSQL)
# SECURITY: Change these credentials for production!
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=CHANGE_ME_local_dev_only
PGDATABASE=hartonomous
PGSSLMODE=prefer

# Connection Pool
POOL_MIN_SIZE=5
POOL_MAX_SIZE=20
POOL_TIMEOUT=30
POOL_MAX_IDLE=600

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=DEBUG

# API Versioning
API_V1_PREFIX=/v1

# CORS (Development)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Authentication (Disabled for local dev)
# SECURITY: Enable and set strong keys for production!
AUTH_ENABLED=false
# AUTH_SECRET_KEY=CHANGE_ME_generate_random_256bit_key

# AGE Worker (EXPERIMENTAL - Disabled by default)
AGE_WORKER_ENABLED=false
AGE_WORKER_POLL_INTERVAL=5

# Neo4j Provenance (RECOMMENDED - Production-ready)
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_dev_password
NEO4J_DATABASE=neo4j

# ====================================
# AZURE PRODUCTION MODE
# ====================================
# Uncomment and configure for Azure deployment:

# USE_AZURE_CONFIG=true
# KEY_VAULT_URL=https://YOUR-VAULT-NAME.vault.azure.net/
# APP_CONFIG_ENDPOINT=https://YOUR-CONFIG-NAME.azconfig.io
# AZURE_CLIENT_ID=YOUR-MANAGED-IDENTITY-CLIENT-ID  # Optional (system-assigned if not set)

# ====================================
# ENTRA ID (Workforce - Internal Applications)
# ====================================
# AUTH_ENABLED=true
# ENTRA_TENANT_ID=6c9c44c4-f04b-4b5f-bea0-f1069179799c
# ENTRA_CLIENT_ID=2e54ba10-1d6e-4a8e-a100-6f84a586e7bf
# ENTRA_CLIENT_SECRET=<from-key-vault-AzureAd-ClientSecret>

# ====================================
# CIAM / EXTERNAL ID (Customers - External Users)
# ====================================
# CIAM_ENABLED=true
# CIAM_TENANT_ID=1816887e-0796-4065-899f-a7478b3918d7
# CIAM_TENANT_NAME=hartonomous
# CIAM_AUTHORITY=https://hartonomous.ciamlogin.com/hartonomous.onmicrosoft.com
# CIAM_CLIENT_ID=<create-app-registration-in-ciam-tenant>
# CIAM_CLIENT_SECRET=<from-key-vault-CIAM-ClientSecret>

# Note: B2C is deprecated, use CIAM (External ID) instead
# Azure AD B2C is no longer available for new customers as of May 1, 2025
