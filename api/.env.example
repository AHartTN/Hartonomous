# Hartonomous API - Local Development Configuration
# For Azure deployment, set USE_AZURE_CONFIG=true

# ====================================
# DEVELOPMENT MODE (Local)
# ====================================
USE_AZURE_CONFIG=false

# Database (Local PostgreSQL)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-local-password
PGDATABASE=hartonomous
PGSSLMODE=prefer

# Connection Pool
POOL_MIN_SIZE=5
POOL_MAX_SIZE=20
POOL_TIMEOUT=30
POOL_MAX_IDLE=600

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=DEBUG

# API Versioning
API_V1_PREFIX=/v1

# CORS (Development)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Authentication (Disabled for local dev)
AUTH_ENABLED=false
# AUTH_SECRET_KEY=your-secret-key-here

# AGE Worker
AGE_WORKER_ENABLED=true
AGE_WORKER_POLL_INTERVAL=5

# ====================================
# AZURE PRODUCTION MODE
# ====================================
# Uncomment and configure for Azure deployment:

# USE_AZURE_CONFIG=true
# KEY_VAULT_URL=https://kv-hartonomous.vault.azure.net/
# APP_CONFIG_ENDPOINT=https://appconfig-hartonomous.azconfig.io
# AZURE_CLIENT_ID=<managed-identity-client-id>  # Optional (system-assigned if not set)

# ====================================
# ENTRA ID (for authentication)
# ====================================
# ENTRA_TENANT_ID=6c9c44c4-f04b-4b5f-bea0-f1069179799c
# ENTRA_CLIENT_ID=2e54ba10-1d6e-4a8e-a100-6f84a586e7bf

# ====================================
# B2C / CIAM (for external users)
# ====================================
# B2C_ENABLED=false
# B2C_TENANT_NAME=hartonomous
# B2C_CLIENT_ID=<b2c-client-id>
# B2C_POLICY_NAME=B2C_1_signupsignin
