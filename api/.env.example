# Hartonomous API Configuration
# Copy to .env and customize for your environment

# Database Configuration
# Option 1: Full connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hartonomous?sslmode=prefer

# Option 2: Individual components (used if DATABASE_URL not set)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=hartonomous
PGSSLMODE=prefer

# Connection Pool
POOL_MIN_SIZE=5
POOL_MAX_SIZE=20
POOL_TIMEOUT=30
POOL_MAX_IDLE=600

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# API Versioning
API_V1_PREFIX=/v1

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Authentication (not yet implemented)
AUTH_ENABLED=false
# AUTH_SECRET_KEY=your-secret-key-here

# AGE Worker
AGE_WORKER_ENABLED=true
AGE_WORKER_POLL_INTERVAL=5
